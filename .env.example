APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://nadezhda.space

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpn_hub
DB_USERNAME=vpn_hub
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Прод: Resend HTTP API (см. DEPLOY.md). Не smtp.resend.com:465 — на части VPS SMTP блокируется.
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="support@nadezhda.space"
MAIL_FROM_NAME="${APP_NAME}"

# Локальная разработка без отправки:
# MAIL_MAILER=log

# Устаревший вариант (только если хостинг гарантированно пускает исходящий SMTP):
# MAIL_MAILER=smtp
# MAIL_SCHEME=smtps
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_...

# Тестовая подписка в личном кабинете (выдаётся 1 раз на аккаунт, только после подтверждения почты)
# TEST_SUBSCRIPTION_ENABLED=false
# TEST_SUBSCRIPTION_DEVICES=1
# TEST_SUBSCRIPTION_DAYS=1
# TEST_SUBSCRIPTION_QUOTA_GB=2

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Привязка Telegram в профиле (/dashboard/profile): бот (поллер на NLtest) + этот сайт.
# 1) В BotFather создайте бота, имя без @ — TELEGRAM_LINK_BOT_USERNAME.
# 2) TELEGRAM_LINK_INTERNAL_API_TOKEN: длинная случайная строка; то же значение в .env процесса бота на NLtest.
# TELEGRAM_LINK_BOT_USERNAME=
# TELEGRAM_LINK_INTERNAL_API_TOKEN=
# TELEGRAM_LINK_SESSION_TTL_MINUTES=15

# Лендинг: название бренда в шапке (по умолчанию «Надежда»)
# MARKETING_BRAND_NAME=Надежда
# Telegram: по умолчанию техподдержка @nadezhda_tehsup; отдельный URL для блока «Поддержка» — опционально
MARKETING_TELEGRAM_URL=https://t.me/nadezhda_tehsup
# MARKETING_TELEGRAM_SUPPORT_URL=https://t.me/nadezhda_tehsup
# Happ: одноразовый вход в ЛК — #profile-web-page-url → /auth/via-token/…; пусто — APP_URL.
# MARKETING_SUBSCRIPTION_SITE_URL=https://nadezhda.space
# Happ #announce: персонально только «Привязанные устройства» (used/max). Выкл.: false
# MARKETING_SUBSCRIPTION_ANNOUNCE_PERSONALIZE=true
# Первая строка: подсказка про вход на сайт (кнопка ⓘ). Пусто — не показывать.
# MARKETING_SUBSCRIPTION_ANNOUNCE_CABINET_HINT=Для входа в личный кабинет на сайте используйте кнопку ⓘ
# MARKETING_SUBSCRIPTION_ANNOUNCE_LINE_DEVICES=
# Строка с URL в plain-text announce (не гиперссылка). Обычно пусто.
# MARKETING_SUBSCRIPTION_ANNOUNCE_LINE_SITE=
# happ_renew_check_traffic участвует в intent=renew и анонсе (не отдельные кнопки клиента).
# HAPP_RENEW_CHECK_TRAFFIC=false
# MARKETING_ANNOUNCE_SUPPRESS_WHEN_NEEDS_RENEWAL=true
# MARKETING_HAPP_EXHAUSTED_ANNOUNCE_FALLBACK=
# Happ: ссылки в клиенте ведут на /auth/via-token/... (вход в ЛК по токену подписки)
# HAPP_CABINET_LINK_ENABLED=true
# Happ: ping-result=icon (галочка/крестик) или time (мс). Пусто — не передавать.
# HAPP_PING_RESULT=icon
# HAPP_SUBSCRIPTION_PING_ONOPEN_ENABLED=true
# Happ: цвет иконки кнопки «сайт» (color-profile.profileWebPageIconColor): #rgb, #RRGGBB или #RRGGBBAA
# Пустая строка в .env (MARKETING_SUBSCRIPTION_PROFILE_WEB_ICON_COLOR=) — не отправлять color-profile
# MARKETING_SUBSCRIPTION_PROFILE_WEB_ICON_COLOR=#FF4D00FF
# Опционально: общая почта поддержки (футер, оферта, политика). Персональные данные не хранить в репозитории.
# MARKETING_SUPPORT_EMAIL=
# Публичная оферта: дата публикации (дд.мм.гггг)
# MARKETING_OFFER_PUBLISHED_AT=07.04.2026

# Hysteria снята полностью (2026-05-20): Litnets теперь только Xray VLESS Reality на TCP :443.

# SSH-ключи на головном сервере: полные пути. У OpenSSH права только 600, владелец пользователь php-fpm (обычно www-data).
LINK_NL_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/yandex11_ed25519
LINK_NL_IP=158.160.136.187
LINK_NL_SSH_USER=ubuntu
LINK_FI_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/fi_ed25519
LINK_METRICS_CACHE_TTL=45

# Составная проверка связки (админ /admin/servers): TCP с хаба + SSH: маршрут, :443, Xray/x-ui, egress HTTPS
LINK_HEALTH_CACHE_TTL=30
LINK_HEALTH_SSH_TIMEOUT=22
LINK_CLIENT_TCP_PORT=443
LINK_NL_CLIENT_TCP_PORT=443
LINK_FI_CLIENT_TCP_PORT=443
# Litnets (доступы5, 185.121.14.153) — карточка в /admin/servers, онлайн VLESS по SSH
# LINK_HOME_IP=185.121.14.153
# LINK_HOME_SSH_USER=root
# LINK_HOME_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/home_ed25519
# RUVDS (доступыRUVDS, 195.133.198.100) — карточка в /admin/servers, онлайн VLESS по SSH
# LINK_RUVDS_IP=195.133.198.100
# LINK_RUVDS_SSH_USER=root
# LINK_RUVDS_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/ruvds_ed25519
# LINK_RUVDS_CLIENT_TCP_PORT=443
# BG31 (доступы31, 31.22.10.250) — карточка в /admin/servers, онлайн VLESS по SSH
# LINK_BG31_IP=31.22.10.250
# LINK_BG31_SSH_USER=root
# LINK_BG31_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/bg31_ed25519
# LINK_BG31_CLIENT_TCP_PORT=443
# 777 (доступы777, 169.40.15.141) — карточка в /admin/servers, онлайн VLESS по SSH
# LINK_777_IP=169.40.15.141
# LINK_777_SSH_USER=root
# LINK_777_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/777_ed25519
# LINK_777_CLIENT_TCP_PORT=443
# Пороги строк «Ключи» / «Трафик» (трафик в ТБ = 10¹² байт, как у счётчика на экране)
LINK_KEYS_CAPACITY=200
LINK_TRAFFIC_WARN_TB=2
LINK_TRAFFIC_CRIT_TB=3

# Админка /admin (логин отдельно от пользователей Breeze)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 3x-ui: глобальные fallback-креды. Используются, если для конкретной ноды
# не заданы XUI_<KEY>_USER / XUI_<KEY>_PASSWORD. Клиентский URL подписки: {APP_URL}/sub/{token}
XUI_PANEL_USER=
XUI_PANEL_PASSWORD=

# LTE Город 1 (через Yandex белый список). XUI_FI_USER/PASSWORD опциональны —
# по умолчанию возьмётся XUI_PANEL_USER/PASSWORD.
XUI_FI_BASE=
# XUI_FI_USER=
# XUI_FI_PASSWORD=
XUI_FI_SUB_ORIGIN=
XUI_FI_PUB_HOST=
XUI_FI_INBOUND_ID=1
XUI_FI_EMAIL_PREFIX=fi
XUI_FI_FLOW=xtls-rprx-vision
XUI_FI_VLESS_NAME="🇫🇮 Билайн, МТС"
XUI_FI_SERVER_DESC="MTC, beeline"
# XUI_FI_REALITY_SID=

# LTE Город 2 (через Yandex белый список). XUI_NL_USER/PASSWORD опциональны.
XUI_NL_BASE=
# XUI_NL_USER=
# XUI_NL_PASSWORD=
XUI_NL_SUB_ORIGIN=
XUI_NL_PUB_HOST=
XUI_NL_INBOUND_ID=2
XUI_NL_EMAIL_PREFIX=nl
XUI_NL_FLOW=xtls-rprx-vision
XUI_NL_VLESS_NAME="🇳🇱 Мобильная сеть [3]"
XUI_NL_SERVER_DESC="MTC, beeline"
# XUI_NL_REALITY_SID=
# Вторая строка у узла в Happ (вместо «VLESS»); пусто = снова показывать VLESS
# XUI_VLESS_SERVER_DESCRIPTION=LTE · стабильное соединение
# b64 (по умолчанию) = как в примерах socks в доке Happ | dual = #Имя?подпись
# XUI_VLESS_SD_FORMAT=b64
# Имя профиля в Happ (макс. 25 символов); пусто в .env = значение из config/xui.php
SUB_PROFILE_TITLE="Nadezhda 🧭 VPN"
SUB_PROFILE_UPDATE_HOURS=1
# Пробная подписка (те же узлы, что платная): часы / ГБ / устройства
# TRIAL_SUBSCRIPTION_HOURS=3
# TRIAL_SUBSCRIPTION_QUOTA_GB=5
# TRIAL_SUBSCRIPTION_DEVICES=1
# TRIAL_SUBSCRIPTION_CABINET_HOURS_CAP=48
# TRIAL_SUBSCRIPTION_ADMIN_MAX_HOURS=8760
SUB_OUTPUT_B64=0
# Формат GET /sub/{token}: vless строки — SUB_FEED_FORMAT=uri (боевой вариант).
# Xray JSON в теле включают только если SUB_FEED_FORMAT=xray_json (см. SUB_JSON_* ниже).
SUB_FEED_FORMAT=uri
# Общий VLESS-узел Litnets (доступы5 / 185.121.14.153): одна ссылка на всех. Далее FI/NL per-client.
# SUB_EXTRA_ENABLED=true
# SUB_EXTRA_HY2_URI=hy2://user:pass@185.121.14.153:443?insecure=1&obfs=salamander&obfs-password=...
# SUB_EXTRA_VLESS_URI=vless://...   # fallback, если HY2 пуст
# SUB_EXTRA_VLESS_TITLE="🇩🇪 Быстрый Wi-Fi"
# SUB_EXTRA_VLESS_SUBTITLE="Самый быстрый!"
# US194 (доступы194 / 194.110.87.115, AlphaVPS Wi-Fi #3): общая VLESS Reality. Самый первый узел.
# SUB_US194_ENABLED=true
# SUB_US194_VLESS_URI=vless://ba26ce3b-9f13-48b0-bbe4-200308c63934@194.110.87.115:8443?encryption=none&security=reality&type=tcp&sni=www.yandex.ru&fp=chrome&pbk=ZMCVuoam89aU7xZpaV3GUvaqAX0Dy0Fs-ALY0Cxg5S0&sid=68bef26b2fbac1be&spx=%2F
# SUB_US194_VLESS_TITLE="🇺🇸 Быстрый Wi Fi"
# SUB_US194_VLESS_SUBTITLE=
# BG31 (доступы31 / 31.22.10.250): общая VLESS, одна ссылка на всех. Второй узел в подписке.
# SUB_BG31_ENABLED=true
# SUB_BG31_VLESS_URI=vless://e48f5ddb-da68-469d-8063-4da527f9585e@31.22.10.250:8443?encryption=none&security=reality&type=tcp&sni=www.yandex.ru&fp=chrome&pbk=mXc_JtdhK0uQl1rkB3mFOKVfSL4d1l9_Jz8E78lhjVE&sid=9f8f79dd6ac45f60&spx=%2F
# SUB_BG31_VLESS_TITLE="🇩🇪 Быстрый Wi-Fi"
# SUB_BG31_VLESS_SUBTITLE=
# 777 (доступы777 / 169.40.15.141): общая VLESS, одна ссылка на всех. После BG31, перед RUVDS.
# SUB_777_ENABLED=true
# SUB_777_VLESS_URI=vless://8514d862-4b38-4c67-9d81-036919822285@169.40.15.141:443?type=tcp&security=reality&sni=www.microsoft.com&fp=chrome&pbk=gmRh1p7ByPBKYm4baCj9Oh7vTKbmbbssuJ7LCGHQTVg&sid=a1b2c3d4&spx=%2F&flow=xtls-rprx-vision
# SUB_777_VLESS_TITLE="🇧🇬 Быстрый Wi--Fi"
# SUB_777_VLESS_SUBTITLE=
# RUVDS (доступыRUVDS / 195.133.198.100): общая VLESS, одна ссылка на всех. После 777, перед CDN.
# SUB_RUVDS_ENABLED=true
# SUB_RUVDS_VLESS_URI=vless://fd62b6cf-640d-4cef-9ab8-bf7ed397f5b2@195.133.198.100:443?security=reality&encryption=none&type=tcp&sni=www.yandex.ru&fp=chrome&pbk=lGu4gSRvqFSQ5z581ii5XK67SZ48EFTDiFzv6YXlOHM&sid=540bc43939cc2abb&flow=xtls-rprx-vision
# SUB_RUVDS_VLESS_TITLE="🇭🇰 МегаФон, Теле2, Йота"
# SUB_RUVDS_VLESS_SUBTITLE=
# NL75 (доступы4 / 222.167.208.75): общая VLESS, одна ссылка на всех. Перед CDN.
# SUB_NL75_ENABLED=false
# SUB_NL75_VLESS_URI=
# SUB_NL75_VLESS_TITLE="🇳🇱 Быстрый Wi~Fi"
# SUB_NL75_VLESS_SUBTITLE=
# CDN xhttp (cdn.nadezhda.space → 158.160.200.205, egress Hostkey NL): общая VLESS вместо per-client FI.
# SUB_CDN_ENABLED=true
# SUB_CDN_VLESS_URI=vless://...@cdn.nadezhda.space:443?encryption=none&security=tls&sni=cdn.nadezhda.space&fp=chrome&type=xhttp&path=%2Fapi%2Fv1%2Fupload%2F&host=cdn.nadezhda.space&mode=packet-up&extra=...
# SUB_CDN_VLESS_TITLE="🇫🇮 Обход глушилок LTE"
# SUB_CDN_VLESS_SUBTITLE=
# Digital CDN xhttp (nadezhda.digital → Yandex CDN → Hostkey 82.24.19.230): последний узел, 🇳🇱.
# SUB_DIGITAL_CDN_ENABLED=true
# SUB_DIGITAL_CDN_VLESS_URI=vless://...@nadezhda.digital:443?encryption=none&security=tls&sni=nadezhda.digital&fp=chrome&type=xhttp&path=%2Fapi%2Fv1%2Fupload%2F&host=nadezhda.digital&mode=packet-up&extra=...
# SUB_DIGITAL_CDN_VLESS_TITLE="🇳🇱 Обход глушилок LTE"
# SUB_DIGITAL_CDN_VLESS_SUBTITLE=
# Удалено: SUB_YANDEX_DIRECT_* (второй CDN «Банки» /api/v2/yandex-direct/)
# NL shared (доступы11 / 158.160.136.187): общая VLESS вместо per-client с 208.31. После FI [2].
# SUB_NL_SHARED_ENABLED=true
# SUB_NL_SHARED_VLESS_URI=vless://...@158.160.136.187:443?encryption=none&flow=xtls-rprx-vision&fp=chrome&pbk=...&security=reality&sid=...&sni=www.icloud.com&type=tcp
# SUB_NL_SHARED_VLESS_TITLE="🇷🇺 Тестирование"
# SUB_NL_SHARED_VLESS_SUBTITLE=
# SUB_FEED_FORMAT=xray_json
# Строки SUB_JSON_* учитываются только при SUB_FEED_FORMAT=xray_json:

# Текст в meta.serverDescription в JSON если задан явно (иначе строка собирается по узлам FI/NL)
# SUB_JSON_META_SERVER_DESCRIPTION=
# Перед JSON добавить те же vless строки, что в режиме uri (по умолчанию 1 — нужно для многих телефонов Happ).
# SUB_JSON_PREPEND_SHARE_LINES=1
# В префиксе оставить vless:// (1, по умолчанию) или только JSON.
# SUB_JSON_PREPEND_VLESS=0
# При prepend=true: вкладывать Xray JSON в тело после share-линий (1/always) или отключить (0/never). Пустое = auto:
# если в префиксе есть vless:// — JSON не вкладывать (дубли LTE + LTE|JSON на десктопе Happ).
# SUB_JSON_EMBED_PROFILES=1
# SUB_JSON_EMBED_PROFILES=never
# FI+NL в JSON: per_node (по умолчанию — отдельный JSON на каждый LTE, заметнее в Happ) или merged — один файл + balancer.
# SUB_JSON_BUNDLE_MODE=per_node
# SUB_JSON_BUNDLE_MODE=merged
# Красивый отступ только для режима merged
# SUB_JSON_PRETTY_PRINT=0
# Серые строки Happ (перекрывают XUI_*_SERVER_DESC, если заданы)
# SUB_GRAY_FI=
# SUB_GRAY_NL=
# SUB_GRAY_TRIAL=
# SUB_GRAY_HOME=
# Длина подписи serverDescription / meta.serverDescription для Happ (по доке премиума — 30; максимум в конфиге 160)
# HAPP_SERVER_DESCRIPTION_MAX_CHARS=30
# Устаревший синоним (если задан и не задан HAPP_SERVER_DESCRIPTION_MAX_CHARS):
# HAPP_FRAGMENT_SUBTITLE_MAX_CHARS=30
# Подписка /sub/{token}: требовать X-Hwid от Happ и хранить до N устройств (false — для curl без заголовка)
SUBSCRIPTION_FEED_REQUIRE_HWID=true
# Happ Provider ID: заголовок providerid и строка #providerid в теле (док: https://www.happ.su/main/ru/dev-docs/provider-id). Домен подписки добавить в кабинет happ-proxy.com.
# Для всех токенов /sub/*
# HAPP_PROVIDER_ID=
# Только выбранные токены — одна строка JSON (ключ = token из URL):
# HAPP_PROVIDER_ID_BY_TOKEN={"5v6lia1K":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"}
# Тестовая подписка /sub: ответ по маршрутизации такой же как у платных (happ://routing/off или профиль при HAPP_ROUTING_ENABLED=true)
# TEST_KEYS_APPLY_HAPP_ROUTING — устарело, флаг не используется
# Лимит часов для выдачи из админки (по умолчанию 8760 ч ≈ 1 год); самовыдача из ЛК остаётся до 48 ч
# TEST_KEYS_ADMIN_MAX_HOURS=8760
# Happ routing: по умолчанию ВКЛ — push-only direct, block ads, geo .dat с зеркала RUVDS.
# HAPP_ROUTING_ENABLED=true
# HAPP_ROUTING_OFF_WHEN_RUVDS=false
# HAPP_ROUTING_SEND_OFF_WHEN_DISABLED=true
# HAPP_ROUTING_ONADD=true
# HAPP_ROUTING_PROFILE_NAME=nadezhda
# geo .dat — зеркало на RUVDS (не GitHub). Loyalsoldier > ~50 МБ RAM в Happ — риск на старых телефонах.
# HAPP_ROUTING_PROFILE_NAME=direct
# HAPP_GEOIP_URL=
# HAPP_GEOSITE_URL=
# HAPP_DIRECT_SITES=domain:ozon.ru,domain:wildberries.ru,... (полный список в config/xui.php)
# HAPP_DIRECT_IP=
# HAPP_BLOCK_SITES=
# Кэш опроса панелей на странице админки «Отчёт» (секунды)
XUI_REPORT_TRAFFIC_CACHE_TTL=60

# WATA (платежи): H2H links + webhooks
# Боевой: https://api.wata.pro/api/h2h/ | Sandbox: https://api-sandbox.wata.pro/api/h2h/
# Токен (Bearer) создаётся в ЛК терминала; не коммитьте в git.
# WATA_BASE_URL=https://api.wata.pro/api/h2h/
# WATA_ACCESS_TOKEN=
# PublicId терминала (из ЛК / из payload JWT) — для справки, виджет опционален
# WATA_TERMINAL_PUBLIC_ID=
# WATA_WEBHOOK_URL=https://nadezhda.space/payments/wata/webhook
# WATA_SUCCESS_URL=https://nadezhda.space/spasibo
# WATA_FAIL_URL=https://nadezhda.space/oshibka
