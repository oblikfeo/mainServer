APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://nadezhda.space

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpn_hub
DB_USERNAME=vpn_hub
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@nadezhda.space"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (отправка писем через Resend)
# 1) В Resend домен должен быть Verified
# 2) На проде выставить:
#    MAIL_MAILER=resend
#    RESEND_API_KEY=...
# 3) From-адрес должен быть на верифицированном домене Resend (например support@nadezhda.space)
# RESEND_API_KEY=

# Тестовая подписка в личном кабинете (выдаётся 1 раз на аккаунт, только после подтверждения почты)
# TEST_SUBSCRIPTION_ENABLED=false
# TEST_SUBSCRIPTION_DEVICES=1
# TEST_SUBSCRIPTION_DAYS=1
# TEST_SUBSCRIPTION_QUOTA_GB=2

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Привязка Telegram в профиле (/dashboard/profile): бот (поллер на NLtest) + этот сайт.
# 1) В BotFather создайте бота, имя без @ — TELEGRAM_LINK_BOT_USERNAME.
# 2) TELEGRAM_LINK_INTERNAL_API_TOKEN: длинная случайная строка; то же значение в .env процесса бота на NLtest.
# TELEGRAM_LINK_BOT_USERNAME=
# TELEGRAM_LINK_INTERNAL_API_TOKEN=
# TELEGRAM_LINK_SESSION_TTL_MINUTES=15

# Лендинг: название бренда в шапке (по умолчанию «Надежда»)
# MARKETING_BRAND_NAME=Надежда
# Telegram: по умолчанию техподдержка @nadezhda_tehsup; отдельный URL для блока «Поддержка» — опционально
MARKETING_TELEGRAM_URL=https://t.me/nadezhda_tehsup
# MARKETING_TELEGRAM_SUPPORT_URL=https://t.me/nadezhda_tehsup
# Happ: одноразовый вход в ЛК — #profile-web-page-url → /auth/via-token/…; пусто — APP_URL.
# MARKETING_SUBSCRIPTION_SITE_URL=https://nadezhda.space
# Happ #announce: персонально только «Привязанные устройства» (used/max). Выкл.: false
# MARKETING_SUBSCRIPTION_ANNOUNCE_PERSONALIZE=true
# Первая строка: подсказка про вход на сайт (кнопка ⓘ). Пусто — не показывать.
# MARKETING_SUBSCRIPTION_ANNOUNCE_CABINET_HINT=Для входа в личный кабинет на сайте используйте кнопку ⓘ
# MARKETING_SUBSCRIPTION_ANNOUNCE_LINE_DEVICES=
# Строка с URL в plain-text announce (не гиперссылка). Обычно пусто.
# MARKETING_SUBSCRIPTION_ANNOUNCE_LINE_SITE=
# happ_renew_check_traffic участвует в intent=renew и анонсе (не отдельные кнопки клиента).
# HAPP_RENEW_CHECK_TRAFFIC=false
# MARKETING_ANNOUNCE_SUPPRESS_WHEN_NEEDS_RENEWAL=true
# MARKETING_HAPP_EXHAUSTED_ANNOUNCE_FALLBACK=
# Happ: ссылки в клиенте ведут на /auth/via-token/... (вход в ЛК по токену подписки)
# HAPP_CABINET_LINK_ENABLED=true
# Happ: цвет иконки кнопки «сайт» (color-profile.profileWebPageIconColor): #rgb, #RRGGBB или #RRGGBBAA
# Пустая строка в .env (MARKETING_SUBSCRIPTION_PROFILE_WEB_ICON_COLOR=) — не отправлять color-profile
# MARKETING_SUBSCRIPTION_PROFILE_WEB_ICON_COLOR=#FF4D00FF
# Опционально: общая почта поддержки (футер, оферта, политика). Персональные данные не хранить в репозитории.
# MARKETING_SUPPORT_EMAIL=
# Публичная оферта: дата публикации (дд.мм.гггг)
# MARKETING_OFFER_PUBLISHED_AT=07.04.2026

# Hysteria2 (Blitz): per-user управление через SSH.
# Включить после установки Blitz на сервере и копирования SSH-ключа на хаб.
HY2_ENABLED=false
HY2_HOST=222.167.208.75
HY2_PORT=443
HY2_OBFS_PASSWORD=
HY2_PIN_SHA256=
HY2_INSECURE=true
HY2_DISPLAY_NAME="🇭🇰 Высокая скорость"
# Серая подпись HY2 в Happ: HY2_GRAY_SUBTITLE или SUB_GRAY_HY2 (если пусто — HY2_SERVER_DESC).
# HY2_GRAY_SUBTITLE=
# SUB_GRAY_HY2=
HY2_SERVER_DESC="Wi-Fi — высокая скорость, без LTE"
HY2_SSH_HOST=222.167.208.75
HY2_SSH_USER=root
HY2_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/hy2_ed25519
# HY2_CLI_PATH=/etc/hysteria/core/cli.py
# HY2_VENV_ACTIVATE=/etc/hysteria/hysteria2_venv/bin/activate

# SSH-ключи на головном сервере: полные пути. У OpenSSH права только 600, владелец пользователь php-fpm (обычно www-data).
LINK_NL_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/nl_ed25519
LINK_FI_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/fi_ed25519
LINK_METRICS_CACHE_TTL=45

# Составная проверка связки (админ /admin/servers): TCP с хаба + SSH: маршрут, :443, Xray/x-ui, egress HTTPS
LINK_HEALTH_CACHE_TTL=30
LINK_HEALTH_SSH_TIMEOUT=22
LINK_CLIENT_TCP_PORT=443
LINK_NL_CLIENT_TCP_PORT=443
LINK_FI_CLIENT_TCP_PORT=443
# Карточка Hysteria2 в /admin/servers: по умолчанию те же HY2_*; при необходимости переопределить
# LINK_HY2_IP=222.167.208.75
# LINK_HY2_SSH_KEY=
# LINK_HY2_CLIENT_TCP_PORT=443

# Пороги строк «Ключи» / «Трафик» (трафик в ТБ = 10¹² байт, как у счётчика на экране)
LINK_KEYS_CAPACITY=200
LINK_TRAFFIC_WARN_TB=2
LINK_TRAFFIC_CRIT_TB=3

# Админка /admin (логин отдельно от пользователей Breeze)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 3x-ui: глобальные fallback-креды. Используются, если для конкретной ноды
# не заданы XUI_<KEY>_USER / XUI_<KEY>_PASSWORD. Клиентский URL подписки: {APP_URL}/sub/{token}
XUI_PANEL_USER=
XUI_PANEL_PASSWORD=

# LTE Город 1 (через Yandex белый список). XUI_FI_USER/PASSWORD опциональны —
# по умолчанию возьмётся XUI_PANEL_USER/PASSWORD.
XUI_FI_BASE=
# XUI_FI_USER=
# XUI_FI_PASSWORD=
XUI_FI_SUB_ORIGIN=
XUI_FI_PUB_HOST=
XUI_FI_INBOUND_ID=1
XUI_FI_EMAIL_PREFIX=fi
XUI_FI_FLOW=xtls-rprx-vision
XUI_FI_VLESS_NAME="🇫🇮 LTE Город 1 🏙️"
XUI_FI_SERVER_DESC="LTE Финляндия — основной узел"
# XUI_FI_REALITY_SID=

# LTE Город 2 (через Yandex белый список). XUI_NL_USER/PASSWORD опциональны.
XUI_NL_BASE=
# XUI_NL_USER=
# XUI_NL_PASSWORD=
XUI_NL_SUB_ORIGIN=
XUI_NL_PUB_HOST=
XUI_NL_INBOUND_ID=2
XUI_NL_EMAIL_PREFIX=nl
XUI_NL_FLOW=xtls-rprx-vision
XUI_NL_VLESS_NAME="🇳🇱 LTE Город 2 🏙️"
XUI_NL_SERVER_DESC="LTE Нидерланды — запасной узел"
# XUI_NL_REALITY_SID=
# Вторая строка у узла в Happ (вместо «VLESS»); пусто = снова показывать VLESS
# XUI_VLESS_SERVER_DESCRIPTION=LTE · стабильное соединение
# b64 (по умолчанию) = как в примерах socks в доке Happ | dual = #Имя?подпись
# XUI_VLESS_SD_FORMAT=b64
# Имя профиля в Happ (макс. 25 символов); пусто в .env = значение из config/xui.php
SUB_PROFILE_TITLE="Nadezhda 🧭 VPN"
SUB_PROFILE_UPDATE_HOURS=12
SUB_OUTPUT_B64=0
# Формат GET /sub/{token}: только строки hy2+vless — SUB_FEED_FORMAT=uri (боевой вариант).
# Xray JSON в теле включают только если SUB_FEED_FORMAT=xray_json (см. SUB_JSON_* ниже).
SUB_FEED_FORMAT=uri
# SUB_FEED_FORMAT=xray_json
# Строки SUB_JSON_* учитываются только при SUB_FEED_FORMAT=xray_json:

# Текст в meta.serverDescription в JSON если задан явно (иначе строка собирается по узлам FI/NL)
# SUB_JSON_META_SERVER_DESCRIPTION=
# После блока JSON на новую строку дописать hy2:// если HY2 включён (игнорируется если SUB_JSON_PREPEND_SHARE_LINES=1).
SUB_JSON_APPEND_HY2=true
# Перед JSON добавить те же hy2/vless строки, что в режиме uri (по умолчанию 1 — нужно для многих телефонов Happ).
# SUB_JSON_PREPEND_SHARE_LINES=1
# В этом префиксе оставить vless:// (1, по умолчанию) или только hy2 — VLESS только из JSON; 0 ломает многие сборки Happ на телефоне и добавляет JSON-профили на ПК.
# SUB_JSON_PREPEND_VLESS=0
# При prepend=true: вкладывать Xray JSON в тело после share-линий (1/always) или отключить (0/never). Пустое = auto:
# если в префиксе есть vless:// — JSON не вкладывать (дубли LTE + LTE|JSON на десктопе Happ); только hy2 + JSON или без префикса — JSON вкладывается.
# SUB_JSON_EMBED_PROFILES=1
# SUB_JSON_EMBED_PROFILES=never
# FI+NL в JSON: per_node (по умолчанию — отдельный JSON на каждый LTE, заметнее в Happ) или merged — один файл + balancer.
# SUB_JSON_BUNDLE_MODE=per_node
# SUB_JSON_BUNDLE_MODE=merged
# Красивый отступ только для режима merged
# SUB_JSON_PRETTY_PRINT=0
# Серые строки Happ (перекрывают XUI_*_SERVER_DESC / HY2_SERVER_DESC, если заданы)
# SUB_GRAY_FI=
# SUB_GRAY_NL=
# SUB_GRAY_HY2=
# SUB_GRAY_TRIAL=
# Длина подписи в URI-фрагменте vless/hy2 (для JSON meta лимит другой — не режем)
# HAPP_FRAGMENT_SUBTITLE_MAX_CHARS=96
# Подписка /sub/{token}: требовать X-Hwid от Happ и хранить до N устройств (false — для curl без заголовка)
SUBSCRIPTION_FEED_REQUIRE_HWID=true
# Тестовая подписка /sub по TestKey: прикладывать HAPP_ROUTING как у платных (по умолчанию отключено в config)
# TEST_KEYS_APPLY_HAPP_ROUTING=true
# Лимит часов для выдачи из админки (по умолчанию 8760 ч ≈ 1 год); самовыдача из ЛК остаётся до 48 ч
# TEST_KEYS_ADMIN_MAX_HOURS=8760
# Happ routing: DirectSites (обход прокси). Пример — 2ip.ru виден без VPN. @see https://www.happ.su/main/dev-docs/routing
# HAPP_ROUTING_ENABLED=true
# HAPP_ROUTING_ONADD=true
# HAPP_ROUTING_PROFILE_NAME=direct
# HAPP_DIRECT_SITES=domain:2ip.ru,full:2ip.ru,full:www.2ip.ru,keyword:2ip.ru,domain:ozon.ru,full:www.ozon.ru,full:api.ozon.ru
# Кэш опроса панелей на странице админки «Отчёт» (секунды)
XUI_REPORT_TRAFFIC_CACHE_TTL=60

# WATA (платежи): H2H links + webhooks
# Боевой: https://api.wata.pro/api/h2h/ | Sandbox: https://api-sandbox.wata.pro/api/h2h/
# Токен (Bearer) создаётся в ЛК терминала; не коммитьте в git.
# WATA_BASE_URL=https://api.wata.pro/api/h2h/
# WATA_ACCESS_TOKEN=
# PublicId терминала (из ЛК / из payload JWT) — для справки, виджет опционален
# WATA_TERMINAL_PUBLIC_ID=
# WATA_WEBHOOK_URL=https://nadezhda.space/payments/wata/webhook
# WATA_SUCCESS_URL=https://nadezhda.space/spasibo
# WATA_FAIL_URL=https://nadezhda.space/oshibka
