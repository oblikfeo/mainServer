APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpn_hub
DB_USERNAME=vpn_hub
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SSH-ключи на головном сервере: полные пути. У OpenSSH права только 600, владелец пользователь php-fpm (обычно www-data).
LINK_NL_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/nl_ed25519
LINK_FI_SSH_KEY=/var/www/vpn-hub/storage/app/ssh/fi_ed25519
LINK_METRICS_CACHE_TTL=45

# Пороги строк «Ключи» / «Трафик» (трафик в ТБ = 10¹² байт, как у счётчика на экране)
LINK_KEYS_CAPACITY=200
LINK_TRAFFIC_WARN_TB=2
LINK_TRAFFIC_CRIT_TB=3

# Админка /admin (логин отдельно от пользователей Breeze)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
